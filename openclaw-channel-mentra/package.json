  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-channel",
    "mentra",
    "mentraos",
    "smart-glasses",
    "g2",
    "channel"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/openclaw-channel-mentra"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "dependencies": {
    "@mentra/sdk": "^1.0.0"
  },
  "devDependencies": {
    "openclaw": "^2026.3.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
