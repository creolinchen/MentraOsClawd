{
  "name": "openclaw-channel-mentra",
  "version": "1.0.0",
  "description": "MentraOS G2 Smart Glasses as a native voice/display channel in OpenClaw",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./index.ts"]
