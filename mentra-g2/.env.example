# MentraOS package name — register at console.mentra.glass
PACKAGE_NAME=com.deinname.mentrag2

# Port for the callback HTTP server (receives responses from the OpenClaw plugin)
PORT=3000

# API key from console.mentra.glass
MENTRA_API_KEY=dein_key_von_console.mentra.glass

# Base URL of the openclaw-channel-mentra plugin HTTP server
PLUGIN_URL=http://localhost:4747
